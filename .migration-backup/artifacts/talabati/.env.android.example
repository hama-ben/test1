# ─────────────────────────────────────────────────────────────────
# ANDROID BUILD — environment variables
# Copy this file to .env.production.local and fill in real values.
# NEVER commit .env.production.local to version control.
# ─────────────────────────────────────────────────────────────────

# Supabase project URL (find it in Supabase → Settings → API)
SUPABASE_URL=https://your-project.supabase.co

# Supabase anon/public key (find it in Supabase → Settings → API)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Full URL of your PUBLISHED Replit API server (no trailing slash).
# This is the URL shown in the Replit "Deployments" tab, e.g.:
#   https://talabati--yourusername.replit.app
# The Android WebView cannot use relative /api/... paths — it must call
# the real deployed server directly.
VITE_API_BASE_URL=https://mizu-final.onrender.com
