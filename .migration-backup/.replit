run = "npm run dev"
modules = ["nodejs-20", "web", "bash", "python-3.11", "postgresql-16"]

[deployment]
deploymentTarget = "cloudrun"
run = ["node", "artifacts/api-server/dist/index.mjs"]
build = ["bash", "-c", "pnpm install --frozen-lockfile && pnpm --filter @workspace/talabati run build && pnpm --filter @workspace/api-server run build"]

[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[workflows]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 3000

[[ports]]
localPort = 19283
externalPort = 3001

[nix]
channel = "stable-25_05"

[userenv]

